<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.management.jupiter.fx.controllers.AdminDashboardController">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: #1976D2;">
               <children>
                  <Label fx:id="welcomeLabel" text="Bienvenido, Administrador" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="20.0" />
                     </HBox.margin>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="logoutButton" mnemonicParsing="false" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Cerrar Sesión">
                     <HBox.margin>
                        <Insets right="20.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="1200.0" style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
               <children>
                  <Button fx:id="refreshButton" mnemonicParsing="false" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Actualizar">
                     <HBox.margin>
                        <Insets left="20.0" right="10.0" />
                     </HBox.margin>
                  </Button>
                  <Label text="Panel de Administración - JUPITER Management System">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <TabPane fx:id="mainTabPane" prefHeight="700.0" prefWidth="1200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
         <tabs>
            <Tab fx:id="usersTab" text="Usuarios">
               <content>
                  <VBox prefHeight="700.0" prefWidth="1200.0" spacing="10.0">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="1160.0" spacing="10.0">
                           <children>
                              <Button fx:id="createUserButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Crear Usuario" />
                              <Button fx:id="editUserButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Editar Usuario" />
                              <Button fx:id="deleteUserButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Eliminar Usuario" />
                              <Button fx:id="filterUsersButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="&#x1F50D; Filtrar" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Gestión de Usuarios" />
                           </children>
                        </HBox>
                        <TableView fx:id="usersTable" prefHeight="600.0" prefWidth="1160.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="userIdColumn" prefWidth="100.0" text="No." />
                            <TableColumn fx:id="usernameColumn" prefWidth="200.0" text="Usuario" />
                            <TableColumn fx:id="emailColumn" prefWidth="250.0" text="Email" />
                            <TableColumn fx:id="roleColumn" prefWidth="150.0" text="Rol" />
                            <TableColumn fx:id="clanColumn" prefWidth="200.0" text="Clan" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </content>
            </Tab>
            <Tab fx:id="clansTab" text="Clanes">
               <content>
                  <VBox prefHeight="700.0" prefWidth="1200.0" spacing="10.0">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="1160.0" spacing="10.0">
                           <children>
                              <Button fx:id="createClanButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Crear Clan" />
                              <Button fx:id="editClanButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Editar Clan" />
                              <Button fx:id="deleteClanButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Eliminar Clan" />
                              <Button fx:id="importCodersButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" text="Importar Coders CSV" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Gestión de Clanes" />
                           </children>
                        </HBox>
                        <TableView fx:id="clansTable" prefHeight="600.0" prefWidth="1160.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="clanIdColumn" prefWidth="100.0" text="No." />
                            <TableColumn fx:id="clanNameColumn" prefWidth="250.0" text="Nombre del Clan" />
                            <TableColumn fx:id="clanDescColumn" prefWidth="350.0" text="Descripción" />
                            <TableColumn fx:id="clanSizeColumn" prefWidth="150.0" text="Miembros" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </content>
            </Tab>
            <Tab fx:id="statisticsTab" text="Estadísticas">
               <content>
                  <VBox prefHeight="700.0" prefWidth="1200.0" spacing="20.0">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1976D2;" text="Estadísticas del Sistema" />
                        <GridPane hgap="20.0" prefHeight="600.0" prefWidth="1160.0" vgap="20.0">
                           <children>
                              <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1976D2;" text="Total Usuarios" />
                                    <Label fx:id="totalUsersLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #333;" text="0" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1976D2;" text="Total Clanes" />
                                    <Label fx:id="totalClansLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #333;" text="0" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3);" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1976D2;" text="Administradores" />
                                    <Label fx:id="totalAdminsLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #333;" text="0" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3);" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1976D2;" text="Team Leaders" />
                                    <Label fx:id="totalTlsLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #333;" text="0" />
                                 </children>
                              </VBox>
                              <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3);" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1976D2;" text="Coders" />
                                    <Label fx:id="totalCodersLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #333;" text="0" />
                                 </children>
                              </VBox>
                           </children>
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="100.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="100.0" vgrow="SOMETIMES" />
                           </rowConstraints>
                        </GridPane>
                     </children>
                  </VBox>
               </content>
            </Tab>
         </tabs>
      </TabPane>
   </center>
</BorderPane>
