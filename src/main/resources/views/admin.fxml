<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.management.jupiter.controllers.AdminFXController"
            style="-fx-background-color: #f1f5f9;">
    <stylesheets>
        <String fx:value="/styles/jupiter.css"/>
    </stylesheets>

    <!-- TOP HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 14px 28px; -fx-background-color: #ffffff;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 6, 0, 0, 2);">
            <Label text="⬡" style="-fx-font-size: 22px; -fx-text-fill: #3b82f6;"/>
            <Label fx:id="headerLabel" text="JUPITER  ·  Administration"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Administrator" styleClass="header-user"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="6" styleClass="sidebar"
              style="-fx-padding: 24px 14px; -fx-pref-width: 210px;">

            <Label text="MANAGEMENT"
                   style="-fx-font-size: 10px; -fx-font-weight: 700;
                          -fx-text-fill: #475569; -fx-padding: 8px 8px 8px 8px;"/>

            <Button fx:id="btnClans" text="🏰  Clans"
                    onAction="#handleClans" styleClass="nav-btn"/>
            <Button fx:id="btnTLs" text="👥  Team Leaders"
                    onAction="#handleTLs" styleClass="nav-btn"/>
            <Button fx:id="btnCoders" text="💻  Developers"
                    onAction="#handleCoders" styleClass="nav-btn"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-background-color: #334155;"/>
            <Button text="⬡  Logout" onAction="#handleExit"
                    styleClass="nav-exit-btn"/>
        </VBox>
    </left>

    <!-- CONTENT -->
    <center>
        <AnchorPane fx:id="contentPane"
                    style="-fx-background-color: #f1f5f9;"/>
    </center>
</BorderPane>
